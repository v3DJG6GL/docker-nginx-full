{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":dependencyDashboard"],
  "timezone": "Etc/UTC",
  "labels": ["dependencies"],
  "automerge": true,
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "OpenResty version pinned in the publish workflow (github tag vX.Y.Z.W).",
      "managerFilePatterns": ["/^\\.github/workflows/build\\.yml$/"],
      "matchStrings": ["OPENRESTY_VERSION:\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "openresty/openresty",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.+)$",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "LuaRocks version pinned in the publish workflow.",
      "managerFilePatterns": ["/^\\.github/workflows/build\\.yml$/"],
      "matchStrings": ["LUAROCKS_VERSION:\\s*'(?<currentValue>[^']+)'"],
      "depNameTemplate": "luarocks/luarocks",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.+)$",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "description": "Majors (incl. a new OpenResty nginx-core line): review via dashboard, never auto-merge.",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group GitHub Actions bumps.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    }
  ]
}
